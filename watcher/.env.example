# Required: the block you want to watch.
# Use https://gdl-garbage-watcher.vercel.app/ to click your block, then read
# the coords from the URL bar / the popup, or use any maps tool.
TARGET_LAT=20.6722
TARGET_LON=-103.34875

# Optional: notification radius and poll interval.
# RADIUS_M=150
# POLL_SEC=60

# Optional: log to a file too (otherwise only stdout — systemd captures it).
# LOGFILE=/home/youruser/gdl-garbage-watcher/truck_visits.log

# Optional: shown in Telegram alerts.
# MAP_URL=https://gdl-garbage-watcher.vercel.app/

# Optional: ntfy.sh topic. Pick something hard to guess.
# NTFY_URL=https://ntfy.sh/your-random-topic-here

# Optional: Telegram bot credentials.
# Create a bot via @BotFather, add it as admin to a group/channel,
# get the chat id with a /start@yourbot command and the getUpdates API.
# TG_BOT_TOKEN=
# TG_CHAT_ID=
